      Friction: 0.6
      Restitution: 0.4
      RestitutionThreshold: 0.5

  # ---------------------------------------------------------------
  # PROP — blue cube at right, tall pillar.
  # ---------------------------------------------------------------
  - Entity: 1007
    Name: Cube_Blue
    TransformComponent:
      Translation: [2.5, 1.0, 0.5]
      Rotation:    [0.0, -0.2, 0.0]
      Scale:       [0.6, 2.0, 0.6]
    SpriteRendererComponent:
      Color:        [0.30, 0.55, 1.00, 1.0]
      TilingFactor: 1.0
    RigidBodyComponent:
