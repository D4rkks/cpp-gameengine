  # ---------------------------------------------------------------
  # SUN — directional light. Cast shadows on the floor and props.
  # ---------------------------------------------------------------
  - Entity: 1009
    Name: Sun
    TransformComponent:
      Translation: [0.0, 8.0, 4.0]
      Rotation:    [-0.9, 0.5, 0.0]
      Scale:       [1.0, 1.0, 1.0]
    LightComponent:
      Type: 0
      Color: [1.0, 0.96, 0.88]
      Intensity: 3.5
      Radius: 50.0
      CastShadows: true
      ShadowDistance: 30.0
      ShadowBias: 1.0
      ShadowPCFRadius: 2
      SpotInner: 25.0
      SpotOuter: 35.0
