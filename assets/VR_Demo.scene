      Rotation:    [0.0, 0.8, 0.0]
      Scale:       [0.7, 0.7, 0.7]
    SpriteRendererComponent:
      Color:        [1.00, 0.90, 0.30, 1.0]
      TilingFactor: 1.0
    RigidBodyComponent:
      Type: 0
      FixedRotation: true
      Mass: 0.0
      Friction: 0.6
      RollingFriction: 0.05
